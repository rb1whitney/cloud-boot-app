{
  "packages": [
    "jdk21",
    "maven@3.9.6",
    "terraform@1.7.5",
    "helm@3.14.2",
    "kubectl@1.29.2",
    "skaffold@2.10.1",
    "crossplane-cli@1.15.1",
    "tflint@0.50.3",
    "checkov@3.2.40",
    "conftest@0.49.1",
    "hadolint@2.12.0",
    "opa@1.1.0",
    "gh@2.45.0"
  ],
  "shell": {
    "init_hook": [
      "echo 'Welcome to the modernized cloud-boot-app dev environment!'",
      "echo 'Java version: ' $(java -version 2>&1 | head -n 1)",
      "echo 'Maven version: ' $(mvn -version | head -n 1)"
    ],
    "scripts": {
      "build": "mvn clean package",
      "test": "make test",
      "lint": "make lint",
      "dev": "skaffold dev"
    }
  }
}
